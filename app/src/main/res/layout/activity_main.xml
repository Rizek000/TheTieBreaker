<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: Dice Icon + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="App icon"
                app:srcCompat="@drawable/ic_dice" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_text"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:text="@string/subtitle_text"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Options RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/optionsRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:nestedScrollingEnabled="false" />

        <!-- Add Option Button -->
        <LinearLayout
            android:id="@+id/btnAddOption"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="Add"
                app:srcCompat="@drawable/ic_add" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_add_option"
                android:textColor="@color/amber_accent"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Decide Button -->
        <Button
            android:id="@+id/btnDecide"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/rounded_button"
            android:drawableStart="@drawable/ic_dice"
            android:drawablePadding="8dp"
            android:elevation="8dp"
            android:stateListAnimator="@null"
            android:text="@string/btn_decide"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Result Card -->
        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/result_card_bg"
            android:gravity="center"
            android:minHeight="130dp"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/trophyIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginBottom="8dp"
                android:contentDescription="Trophy"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_trophy" />

            <TextView
                android:id="@+id/rouletteText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/amber_accent"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/winnerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/winner_label"
                android:textColor="@color/winner_green"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:visibility="gone" />

        </LinearLayout>

        <!-- History Section -->
        <LinearLayout
            android:id="@+id/historyHeader"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="28dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="History"
                app:srcCompat="@drawable/ic_history" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/history_title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/historyChevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Expand/collapse"
                app:srcCompat="@drawable/ic_arrow_down" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/historyRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/historyEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:text="@string/history_empty"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
